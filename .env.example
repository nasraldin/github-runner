# Single-pool mode only. Multi-project mode reads repositories from runners.config.json.
GITHUB_OWNER=example-owner
GITHUB_REPO=example-repo

# Production mode, recommended.
# Use a GitHub token owned by an account with admin access to the repo.
# Classic PAT: repo scope.
# Fine-grained PAT: repository access to each configured repo and Administration write.
GITHUB_TOKEN=

# Manual mode, optional.
# Paste the one-hour token from GitHub's "New self-hosted runner" screen only for quick tests.
# Leave empty for production so the container can fetch fresh registration/remove tokens.
GITHUB_RUNNER_REGISTRATION_TOKEN=

# Runner behavior.
RUNNER_REPLICAS=3
RUNNER_NAME_PREFIX=github-runner
RUNNER_GROUP=Default
RUNNER_LABELS=self-hosted,linux,x64,docker
RUNNER_WORKDIR=_work
RUNNER_EPHEMERAL=true
RUNNER_REPLACE_EXISTING=true
RUNNER_DISABLE_UPDATE=false

# Build controls pinned to the Linux x64 runner shown by GitHub for this repo.
BASE_IMAGE=node:lts-bullseye
RUNNER_PLATFORM=linux/amd64
RUNNER_VERSION=2.335.1
RUNNER_SHA256=4ef2f25285f0ae4477f1fe1e346db76d2f3ebf03824e2ddd1973a2819bf6c8cf
RUNNER_IMAGE=github-runner-manager:local

# Optional. Usually auto-detected from /var/run/docker.sock by the entrypoint.
# Set manually if your host Docker socket uses a special group ID.
DOCKER_GID=
